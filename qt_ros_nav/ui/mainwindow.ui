<property name="styleSheet">
   <string notr="true">QMainWindow{
	background-color:#f5f7fa;
    font-size:16px;
}
QTabWidget::pane{
	border:1px solid #e0e0e0;
	border-radius:6px;
	background-color:white;
}
QTabBar::tab{
	min-width:220px;
	min-height:40px;
	font-size:16px;
	padding:4px 10px;
}
QTabBar::tab:selected{
	background-color:qlineargradient(spread:pad, x1:0, y1:0, x2:0, y2:1, stop:0 #73b5ff, stop:1 #4285f4);
	color:white;
	border-radius:6px 6px 0px 0;
}
QPushButton{
	min-height:30px;
	font-size:14px;
	background-color:qlineargradient(spread:pad, x1:0, y1:0, x2:0, y2:1, stop:0 #73b5ff, stop:1 #4285f4);
	color:white;
	border:none;
	border-radius:6px;
}
QPushButton:hover{
	background-color:qlineargradient(spread:pad, x1:0, y1:0, x2:0, y2:1, stop:0 #86c0ff, stop:1 #5294ff);
}
QPushButton:pressed{
	background-color:qlineargradient(spread:pad, x1:0, y1:0, x2:0, y2:1, stop:0 #4285f4, stop:1 #3367d6);
}
QLabel{
	font-size:16px;
}
#label_title{
	font-size:26px;
	font-weight:bold;
	color:#2c3e50;
	min-height:45px;
	qproperty-alignment: 'AlignCenter | AlignVCenter';
}
#label_pick{
	font-size:20px;
	color:#7f8c8d;
}
QGroupBox {
    background-color: #ffffff;
    border: 1px solid #dcdde1;
    border-radius: 6px;
    margin-top: 10px;  /* 减小外边距 */
    padding-top: 2px;  /* 极大地压缩标题和内容部分的巨大空白！ */
}
QGroupBox::title {
    subcontrol-origin: margin;
    left: 10px;
    top: 0px;
    color: #2c3e50;
    font-weight: bold;
}
</string>
